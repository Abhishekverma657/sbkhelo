<%- include('layout/header') %>

  <!-- Date Filters -->
  <div class=" rounded-lg shadow-sm p-6 mb-8">
    <div class="flex flex-wrap gap-4 items-end">
      <div class="flex-1 min-w-0">
        <label for="" class="block text-sm font-medium  mb-2">Start Date</label>
        <input type="date" id="start_date"
          class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
      </div>
      <div class="flex-1 min-w-0">
        <label for="" class="block text-sm font-medium  mb-2">End Date</label>
        <input type="date" id="end_date"
          class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
      </div>
      <div class="flex-shrink-0">
        <button id="filterButton" type="button" onclick="DataSave()"
          class="bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white px-6 py-2 rounded-md font-medium flex items-center gap-2 transition-all duration-200 shadow-md hover:shadow-lg">
          <i class="fas fa-filter"></i>
          <span>Filter</span>
        </button>
      </div>
    </div>
  </div>
  <!-- Cards -->
  <div class="cards">
    <div class="card" onclick="window.location.href='/admin/withdrawls'">
      <div><i class="fa-solid fa-wallet"></i>Agnet Name</div>
      <h2 id="subadmin_name">loading...</h2>
    </div>
    <div class="card" onclick="window.location.href='/admin/withdrawls'">
      <div><i class="fa-solid fa-wallet"></i>Pending withdrawls</div>
      <h2 id="withdrawls__">loading...</h2>
    </div>
    <div class="card">
      <div><i class="fa-solid fa-wallet"></i> My Wallet</div>
      <h2 id="total_amount">loading...</h2>
    </div>
    <div class="card" onclick="window.location.href='/admin/user'">
      <div><i class="fa-solid fa-users"></i> Total Teams</div>
      <h2 id="total_teams">loading...</h2>
    </div>
    <div class="card" onclick="window.location.href='/admin/user'">
      <div><i class="fa-solid fa-signal"></i> User Game All Wallet</div>
      <h2 id="getteamwalle">Loading...</h2>
    </div>
    <div class="card" onclick="window.location.href='/admin/commission'">
      <div><i class="fa-solid fa-chart-line"></i> Commission</div>
      <h2 id="Commission__">Loading...</h2>
    </div>
    <div class="card">
      <div><i class="fa-solid fa-chart-line"></i> Commission Rate</div>
      <h2 id="commission">Loading..</h2>
    </div>
    <div class="bg-yellow-600 text-white p-5 rounded-2xl shadow-lg">
      <div class="flex items-center justify-between text-lg">

        <div class="flex items-center gap-2">
          <i class="fa-solid fa-chart-line"></i>
          <span>Commission</span>
        </div>
        <button class="bg-white text-yellow-700 px-3 py-1 rounded-lg font-semibold hover:bg-yellow-100 transition"
          onclick="takecom()">
          Take
        </button>
      </div>
      <h2 id="winner" class="text-2xl font-bold mt-2">Loading..</h2>
    </div>



  </div>

  <div class=" p-4 " style="display: none;">
    <div class="card p-6 rounded-xl shadow flex-1 flex flex-col">
      <h3 class="text-lg font-bold mb-4">Recent Activity</h3>

      <!-- Filters -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-4">
        <input type="text" placeholder="Search by user or action"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <input type="date" style="color: #000000 !important;"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <input type="date" style="color: #000000 !important;"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <button class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600">Filter</button>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto flex-1">
        <table class="min-w-full border border-gray-200">
          <thead class="bg-gray-200 sticky top-0">
            <tr style="color:#000000">
              <th class="p-3 border">User</th>
              <th class="p-3 border">Action</th>
              <th class="p-3 border">Date</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-3 border">John Doe</td>
              <td class="p-3 border">Edited</td>
              <td class="p-3 border">2024-04-20</td>
            </tr>
            <tr>
              <td class="p-3 border">Jane Smith</td>
              <td class="p-3 border">Updated</td>
              <td class="p-3 border">2024-04-19</td>
            </tr>
            <tr>
              <td class="p-3 border">Kevin Brown</td>
              <td class="p-3 border">Created</td>
              <td class="p-3 border">2024-04-19</td>
            </tr>
            <tr>
              <td class="p-3 border">Mary Johnson</td>
              <td class="p-3 border">Deleted</td>
              <td class="p-3 border">2024-04-18</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="flex justify-between mt-4">
        <div class="mt-4 space-x-2">
          <p class="">Total Pages : <span id="total_pages">0</span></p>
        </div>
        <div class=" mt-4 space-x-2">
          <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100" style="color: #000000 !important;">
            << /button>
              <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100"
                style="color: #000000 !important;">1</button>
              <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100"
                style="color: #000000 !important;">></button>
        </div>
      </div>
    </div>
  </div>




  <%- include('layout/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
      let start_date
      let end_date;
      const username = sessionStorage.getItem('subadmin_name');
      const userid = sessionStorage.getItem('subadmin_userid');
      document.getElementById("subadmin_name").innerHTML = username + " ( id: " + userid + ")";
      window.onload = function () {
        fetchdata();
      }
      function DataSave() {
        end_date = document.getElementById("end_date").value;
        start_date = document.getElementById("start_date").value;
        fetchdata();
      }


      let takeamount;
      function takecom() {
        if (takeamount == 0) {
          Swal.fire({
            icon: "infi",
            title: "Done!",
            text: "Your Commission is 0 "
          });
          return;
        }
        const token = sessionStorage.getItem('subadmin_token');
        Swal.fire({
          title: "Are you sure?",
          text: "You want to take commission?",
          icon: "warning",
          showCancelButton: true,
          confirmButtonText: "Yes, Take",
        }).then((result) => {

          if (result.isConfirmed) {

            const payload = { token };

            fetch("/admin/take", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${Jwt}`
              },
              body: JSON.stringify(payload)
            })
              .then(res => res.json())
              .then(data => {

                if (data.status == 1) {

                  Swal.fire({
                    icon: "success",
                    title: "Done!",
                    text: data.message || "Commission taken successfully"
                  });
                  fetchdata();
                } else {

                  Swal.fire({
                    icon: "error",
                    title: "Failed",
                    text: data.message || "Something went wrong"
                  });

                }

              }).catch(() => {

                Swal.fire({
                  icon: "error",
                  title: "Server Error"
                });

              });

          }

        });

      }

      function fetchdata() {
        const token = sessionStorage.getItem('subadmin_token');
        // Create the payload object
        const payload = {
          token,
          start_date,
          end_date
        };
        // Call the API using fetch
        fetch("/admin/dashboard", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status == 1) {
              document.getElementById('total_amount').innerHTML = "₹" + parseFloat(data.userwallet, 2).toFixed(2);
              document.getElementById('total_teams').innerHTML = data.team;

              document.getElementById('getteamwalle').innerHTML = "₹" + parseFloat(data.getteamwalle, 2).toFixed(2);
              document.getElementById('commission').innerHTML = data.commision + " %";
              document.getElementById('Commission__').innerHTML = "₹" + parseFloat(data.total_com, 2).toFixed(2);
              document.getElementById('withdrawls__').innerHTML = "₹" + parseFloat(data.withdrawls, 2).toFixed(2);
              document.getElementById('winner').innerHTML = "₹" + parseFloat(data.winner, 2).toFixed(2);
              takeamount = data.winner;
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }
    </script>