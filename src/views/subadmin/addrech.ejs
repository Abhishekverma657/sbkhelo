  <!-- Add User Modal -->
<div id="blockUserModal1"
  class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
  <div class="w-full max-w-lg rounded-2xl bg-white text-gray-900 shadow-2xl dark:bg-gray-800 dark:text-gray-100">
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-xl font-semibold">Add User / Recharge</h3>
      <button onclick="closedepositModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
        ✕
      </button>
    </div>

    <!-- Body -->
    <form id="blockUserForm" class="px-6 py-5 space-y-6">
      <!-- Search -->
      <div>
        <label for="searchId" class="block text-sm font-medium mb-1">Search User / Mobile</label>
        <input type="text" id="searchId" placeholder="Search user or mobile"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
          focus:outline-none focus:ring-2 focus:ring-blue-400
          dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
      </div>

      <!-- Table -->
      <div class="overflow-hidden border border-gray-200 dark:border-gray-700 rounded-lg">
        <table class="min-w-full text-sm text-left text-gray-600 dark:text-gray-300">
          <tbody id="table2">
            <!-- Dynamic user search results go here -->
          </tbody>
        </table>
      </div>

      <!-- Form Inputs -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Recharge Type -->
        <div>
          <label class="block text-sm font-medium mb-1">Recharge Type</label>
          <select id="reschAdd"
            class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
            focus:outline-none focus:ring-2 focus:ring-blue-400
            dark:border-gray-600 dark:bg-gray-700 dark:text-white">
            <option value="1">Add Deposit</option>
            <!-- <option value="2">Cut Deposit</option> -->
            <!-- <option value="3">Add Withdrawls</option> -->
            <!-- <option value="4">Cut Withdrawls</option> -->
          </select>
        </div>

        <!-- Amount -->
        <div>
          <label class="block text-sm font-medium mb-1">Amount</label>
          <input type="number" id="amountF" placeholder="Enter Amount"
            class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
            focus:outline-none focus:ring-2 focus:ring-blue-400
            dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
        </div>

        <!-- Notifications -->
        <div>
          <label class="block text-sm font-medium mb-1">Notifications</label>
          <select id="NotificationsOn"
            class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
            focus:outline-none focus:ring-2 focus:ring-blue-400
            dark:border-gray-600 dark:bg-gray-700 dark:text-white">
            <option value="1">Not Send</option>
            <option value="2">Send</option>
          </select>
        </div>

        <!-- Message -->
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium mb-1">Message</label>
          <textarea id="nottext" rows="3" placeholder="Enter your message..."
            class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
            focus:outline-none focus:ring-2 focus:ring-blue-400
            dark:border-gray-600 dark:bg-gray-700 dark:text-white resize-none"></textarea>
        </div>
      </div>

      <!-- Hidden Fields -->
      <div class="hidden">
        <label class="block text-sm font-medium mb-1">Type</label>
        <select id="user_type"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
          dark:border-gray-600 dark:bg-gray-700">
          <option selected value="1">User</option>
          <option value="2">Agent</option>
        </select>
      </div>

      <div class="hidden">
        <label class="block text-sm font-medium mb-1">Commission (0 - 10)</label>
        <input type="number" id="user_commission" value="0" placeholder="Enter Commission"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2
          focus:outline-none focus:ring-2 focus:ring-blue-400
          dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
      </div>
    </form>

    <!-- Footer -->
    <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-gray-200 dark:border-gray-700">
      <button onclick="closedepositModal()"
        class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 
        dark:border-gray-600 dark:hover:bg-gray-700">
        Cancel
      </button>
      <button type="button" onclick="MakePayment()"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white hover:bg-blue-700">
        Submit
      </button>
    </div>
  </div>
</div>


   <!-- Delete Confirmation Modal -->
<div id="deleteConfirmModal2"
  class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
  <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold">Confirm Deletion</h3>
      <button onclick="closeDeleteModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
        ✕
      </button>
    </div>
    <!-- Body -->
    <div class="px-5 py-6 text-center">
      <p class="text-base">Are you sure you want to delete this item? This action cannot be undone.</p>
    </div>
    <!-- Footer -->
    <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
      <button onclick="closeDeleteModal()"
        class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
        Cancel
      </button>
      <input type="hidden" id="deltedmode" value="">
      <button type="button" onclick="removedata()"
        class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
        Delete
      </button>
    </div>
  </div>
</div>
  <!-- Success Toast -->
    <div id="successToast"
      class="fixed top-5 right-5 z-50 hidden items-center gap-3 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg shadow-lg animate-slide-in">
      <i class="fa-solid fa-circle-check text-green-500 text-xl"></i>
      <span class="font-medium" id="showerror">this demo panel !</span>
      <button onclick="hideSuccessToast()" class="ml-2 text-green-700 hover:text-green-900 font-bold">
        &times;
      </button>
    </div>

    <!-- JS -->
    <script>
      
      let current_page = 1;
      let total_page = 1;
      let startdate;
      let enddate;
      let searchitem;
      let login_type  = 0;
      function openBlockModal(item) {
        let name = item.getAttribute('data-na');
        let idd = item.getAttribute('data-id');
        let block = item.getAttribute('data-bl');
        document.getElementById("useridd").value = idd;
        console.log(name + " · ID:" + idd);
        document.getElementById('show_user_D').innerHTML = name + " · ID:" + idd + " · " + (block == 0 ? "active" : "block");
        document.getElementById('blockUserModal').classList.remove('hidden');
      }
      function closeBlockModal() {
        document.getElementById('blockUserModal').classList.add('hidden');
      }
      function closeDeleteModal() {
        document.getElementById('deleteConfirmModal2').classList.add('hidden');
      }
      function OpenDeleteModal(para) {
        let idd = para.getAttribute('data-id');
        document.getElementById('deltedmode').value = idd;
        document.getElementById('deleteConfirmModal2').classList.remove('hidden');
      }
      function blockUserAction() {
        closeBlockModal();
        showSuccessToast("this id popup");
      }
      function hidemakepayment(value){
        if(value == 1){
            document.getElementById('blockUserModal1').classList.add('hidden');
        }else{
          document.getElementById('blockUserModal1').classList.remove('hidden');
        }
      }
      function openAddDepositModal() {
        document.getElementById('blockUserModal1').classList.remove('hidden');
      }
      function closedepositModal() {
        console.log("hide popup");

        document.getElementById('blockUserModal1').classList.add('hidden');
      }
      function showSuccessToast(value) {
        document.getElementById("showerror").innerHTML = value;
        const toast = document.getElementById('successToast');
        toast.classList.remove('hidden');
        setTimeout(() => {
          hideSuccessToast();
        }, 3000);
      }
      function hideSuccessToast() {
        document.getElementById('successToast').classList.add('hidden');
      }
    </script>
    <script>
      function fillter(){
        searchitem = document.getElementById('search_bar').value;
        startdate = document.getElementById('startdate').value;
        enddate = document.getElementById('enddate').value;
        getalluser();
      }
    
      // get all user
      getalluser();
      function getalluser() {
        const url = "/admin/addrech";
        const data = {page : current_page , token, role: 'subadmin', startdate, enddate, search: searchitem };
        fetch(url, {
          method: "POST",
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${Jwt}` },
          body: JSON.stringify(data)
        })
          .then(res => res.json())
          .then(result => {
            console.log('API response:', result);            
            total_page = result.totalPages;
            document.getElementById('cureent_pages').innerHTML = current_page;
            document.getElementById('cureent_pages1').innerHTML = current_page;
            document.getElementById('Total_enter').innerHTML = result.total;
            if (result.data && Array.isArray(result.data)) {
              const tableBody = document.getElementById("showdata");
              tableBody.innerHTML = ""; // Clear old data

              result.data.forEach(user => {
                const row = `
            <tr>
              <td class="p-3 border text-center">${user.id}</td>
              <td class="p-1 border text-center">
                <div>
                  <i mr-1 class="fa-solid fa-trash" onclick="OpenDeleteModal(this)" data-id="${user.id}" style="color : red"></i>
                </div>
              </td>
              <td class="p-3 border text-center">${user.userid}</td>
              <td class="p-3 border text-center">${user.mobile}</td>
              <td class="p-3 border text-center">${user.amount}</td>
              <td class="p-3 border text-center">${user.join_time}</td>
            </tr>
          `;
                tableBody.insertAdjacentHTML("beforeend", row);
              });
            } else {
              showSuccessToast("No user data found.");
            }
          })
          .catch(error => {
            console.log('Error:', error);
            showSuccessToast("Server error");
          });
      }

      function nextpage(){
        console.log(current_page, total_page);
        
        if(current_page < total_page){
            current_page++;
            getalluser();
        }
      }
      function backpage(){
        if(current_page > 1){
            current_page--;
            getalluser();
        }
      }

      // add new use
      function SubmitAction() {
        let name = document.getElementById('user_name').value.trim();
        let mobile = document.getElementById('user_mobile').value.trim();
        let password = document.getElementById('user_password').value.trim();
        let type = document.getElementById('user_type').value.trim();
        let commission = document.getElementById('user_commission').value.trim();

        if (!name || !mobile || !password || !type || !commission) {
          showSuccessToast("Please fill all the fields.");
          return;
        }
        const token = sessionStorage.getItem('subadmin_token');
        // Create the payload object
        const payload = {
          name: name,
          mobile: mobile,
          password: password,
          type: type,
          commission: commission,
          token
        };

        // Call the API using fetch
        fetch("/admin/add_user", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status === 1) {
              closedepositModal();
              getalluser();
              showSuccessToast(data.message);
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }
      // add new use
      function removedata() {
        let idd = document.getElementById('deltedmode').value;
        const token = sessionStorage.getItem('subadmin_token');
        // Create the payload object
        const payload = {
          idd : idd,
          token,
          tables  : "add_rech"
        };

        // Call the API using fetch
        fetch("/admin/removedata", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status === 1) {
              closeDeleteModal();
              showSuccessToast(data.message);
              getalluser();
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }


      
      
    </script>
    <script>
document.getElementById("searchId").addEventListener("keyup", function () {
    Userfetch();
});

async function Userfetch() {
    let searchItem = document.getElementById("searchId").value;
    if (!searchItem) {
        return;
    }

    const requestDat = { searchItem, token  };

    try {
        const response = await fetch("addDSearch", {
            method: "POST",
            headers: {
                "Content-Type": "application/json", 'Authorization': `Bearer ${Jwt}`
            },
            body: JSON.stringify(requestDat)
        });

        const respona = await response.json();
        const ve = respona.reData;

        const table2 = document.getElementById("table2");
        table2.innerHTML = "";

        ve.forEach(element => {
            const row = document.createElement("tr");
            row.innerHTML =
                "<th data-da='" + element.id + "' onclick='getUser(this)'>" + element.id + "</th>" +
                "<td data-da='" + element.id + "' onclick='getUser(this)'>" + element.mobile + "</td>";
            table2.appendChild(row);
        });

    } catch (error) {
        console.error("Error fetching data:", error);
    }
}
 function getUser(para) {
        let id = para.getAttribute('data-da'); // Corrected method name
        console.log(id, "id");
        if(!id){
            return;
        }
        const table2 = document.getElementById("table2");
        table2.innerHTML = "";
        document.getElementById("searchId").value = id; 
    }
</script>

<script>
async function MakePayment() {
  let reschAdd = document.getElementById("reschAdd").value;
  let amountF = document.getElementById("amountF").value;
  let searchId = document.getElementById("searchId").value;
  let NotificationsOn = document.getElementById("NotificationsOn").value;
  let nottext = document.getElementById("nottext").value;
  let token = sessionStorage.getItem('subadmin_token');
  if (!reschAdd || !amountF || !searchId) {
    swal({
      title: "Parameter Missing!",
      text: "thanks",
      type: "error",
    });
    return;
  }

  if (NotificationsOn == 2 && !nottext) {
    swal({
      title: "Parameter Missing!",
      text: "thank",
      type: "error",
    });
    return;
  }

  const sendData = {
    reschAdd,
    amountF,
    searchId,
    NotificationsOn,
    nottext,
    token
  };

  try {
    const response = await fetch("makePayment1", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",'Authorization': `Bearer ${Jwt}`
      },
      body: JSON.stringify(sendData),
    });

    const respona = await response.json();

    if (respona.status == 1) {
      document.getElementById("amountF").value = "";
      document.getElementById("searchId").value = "";
      document.getElementById("nottext").value = "";
      // close modal
      const closeButton = document.getElementById("closeBtn1");
      if (closeButton) closeButton.click();
      showSuccessToast(respona.message);
      hidemakepayment(1);
      getalluser();
    } else {
      showSuccessToast(respona.message);
      getalluser();
      hidemakepayment(1);
    }
  } catch (error) {
    console.error("Error:", error);
    showSuccessToast(respona.message);
    getalluser();
    hidemakepayment(1);
  }
}

</script>
