<%- include('../layout/header') %>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <div class="card pt-5"></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- ===================== ADMIN POOL TABLE ===================== -->
  <div class="card mb-4">
    <div class="card-header">
      <div class="card-title">Admin Pool & Commission</div>
    </div>
    <div class="card-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>#</th>
            <th>Game Pool</th>
            <th>Admin Profit</th>
            <th>Admin %</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td id="TextGamePool">
              <%= pool.gamepool %>
            </td>
            <td id="TextAdminProfit">
              <%= pool.admin %>
            </td>
            <td id="TextAdminPercent">
              <%= pool.range %>
            </td>
            <td>
              <i class="fas fa-edit text-success" data-bs-toggle="modal" data-bs-target="#modalAdminPool"></i>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ===================== GAME TIME TABLE ===================== -->
  <div class="card mb-4">
    <div class="card-header">
      <div class="card-title">Game Time</div>
    </div>
    <div class="card-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>#</th>
            <th>Open Time</th>
            <th>Close Time</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td id="TextOpenTime">
              <%= pool.open_time %>
            </td>
            <td id="TextCloseTime">
              <%= pool.close_time %>
            </td>
            <td>
              <i class="fas fa-edit text-success" data-bs-toggle="modal" data-bs-target="#modalGameTime"></i>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ===================== CLAIM TIME TABLE ===================== -->
  <div class="card mb-4">
    <div class="card-header">
      <div class="card-title">Claim Time</div>
    </div>
    <div class="card-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>#</th>
            <th>Claim Open</th>
            <th>Claim Close</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td id="TextClaimOpen">
              <%= pool.claim_open %>
            </td>
            <td id="TextClaimClose">
              <%= pool.claim_close %>
            </td>
            <td>
              <i class="fas fa-edit text-success" data-bs-toggle="modal" data-bs-target="#modalClaimTime"></i>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ===================== CLAIM TIME TABLE ===================== -->
  <div class="card mb-4">
    <div class="card-header">
      <div class="card-title">Claim Time</div>
    </div>
    <div class="card-body">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>#</th>
            <th>withdrawal minmun </th>
            <th>Request per day</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td id="withdrawal_min1">
              <%= pool.withdrawal_min %>
            </td>
            <td id="request11">
              <%= pool.request1 %>
            </td>
            <td>
              <i class="fas fa-edit text-success" data-bs-toggle="modal" data-bs-target="#modalAdminPool1"></i>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ===================== MODAL 1 : ADMIN POOL ===================== -->
  <div class="modal fade" id="modalAdminPool">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5>Admin Pool</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input class="form-control mb-2" id="GamePool" type="number" value="<%= pool.gamepool %>"
            placeholder="Game Pool">
          <input class="form-control mb-2" id="adminprofile" type="number" value="<%= pool.admin %>"
            placeholder="Admin Profit">
          <input class="form-control mb-2" id="admincommsion" type="number" value="<%= pool.range %>"
            placeholder="Admin %">
          <button class="btn btn-primary w-100" onclick="updateAdminPool()">Update</button>
        </div>
      </div>
    </div>
  </div>
  <!-- ===================== MODAL 1 : ADMIN POOL ===================== -->
  <div class="modal fade" id="modalAdminPool1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5>Admin Pool</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input class="form-control mb-2" id="withdrawal_min" type="number" value="<%= pool.withdrawal_min %>"
            placeholder="Game Pool">
          <input class="form-control mb-2" id="request1" type="number" value="<%= pool.request1 %>"
            placeholder="Admin Profit">
          <button class="btn btn-primary w-100" onclick="updateAdminPool()">Update</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===================== MODAL 2 : GAME TIME ===================== -->
  <div class="modal fade" id="modalGameTime">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5>Game Time</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input class="form-control mb-2" id="open_time" type="time" value="<%= pool.open_time %>">
          <input class="form-control mb-2" id="close_time" type="time" value="<%= pool.close_time %>">
          <button class="btn btn-primary w-100" onclick="updateAdminPool()">Update</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ===================== MODAL 3 : CLAIM TIME ===================== -->
  <div class="modal fade" id="modalClaimTime">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5>Claim Time</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input class="form-control mb-2" id="claim_open" type="time" value="<%= pool.claim_open %>">
          <input class="form-control mb-2" id="claim_close" type="time" value="<%= pool.claim_close %>">
          <button class="btn btn-primary w-100" onclick="updateAdminPool()">Update</button>
        </div>
      </div>
    </div>


    <script>

      setInterval(async () => {
        await livepool();
      }, 2000);

      async function livepool() {
        try {
          const response = await fetch("/super/livepool", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
          });

          if (!response.ok) {
            throw new Error(`HTTP error! Status: ${response.status}`);
          }

          const data = await response.json();
          // console.log(data.pool, "sdfg");
          document.getElementById("TextGamePool").innerHTML = data.pool;
          // document.getElementById("GamePool").value = data.pool;
        } catch (error) {
          console.error("Livepool API Error:", error.message);
          return null;
        }
      }

      function updateAdminPool() {
        let gamepool = document.getElementById("GamePool").value;
        let adminprofile = document.getElementById("adminprofile").value;
        let admincommsion = document.getElementById("admincommsion").value;
        let open_time = document.getElementById("open_time").value;
        let close_time = document.getElementById("close_time").value;
        let claim_open = document.getElementById("claim_open").value;
        let claim_close = document.getElementById("claim_close").value;
        let withdrawal_min = document.getElementById("withdrawal_min").value;
        let request1 = document.getElementById("request1").value;
        console.log(withdrawal_min , "withdrawal_min" , request1);
        
        if (!gamepool || !adminprofile || !admincommsion || !open_time || !close_time || !claim_open || !claim_close || !request1 || !withdrawal_min) {
          swal("Error", "Paramter are required.", "error");
          return;
        }
        const senddata2 = {
          gamepool, adminprofile, admincommsion, open_time, close_time, claim_close, claim_open, withdrawal_min, request1
        }
        $.ajax({
          url: 'updateGamepool',
          type: 'POST',
          contentType: 'application/json',
          data: JSON.stringify(senddata2),
          success: function (responaD) {
            if (responaD.Qstatus == 1) {
              swal("Success", responaD.message, "success");
              console.log(gamepool, "game");
              setTimeout(() => {
                location.reload();
              }, 1000);
            } else {
              swal("Error", responaD.message, "error");
            }
          }
        });
      }

    </script>
    <%- include('../layout/footer') %>