  <script>
    let page = 1;
    let totalpage = 1;

      function fetchData() {
        const requestData = {
          item: $('#form1').val().trim(),
          page : page,
          tableName : 'recharge',
        };
        const startDate = $('#startDate').val();
        const endDate = $('#endDate').val();
        if (startDate && endDate) {
          requestData.startdate = startDate;
          requestData.enddate = endDate;
        }

        // Make AJAX request to fetch data
        $.ajax({
          url: '/sliderAPi', // Your Node.js API endpoint
          type: 'POST',
          contentType: 'application/json',
          data: JSON.stringify(requestData),
          success: function (response) {
            const user =response; // Corrected this line from 'respona' to 'response'
            var tbody = document.getElementById("tableprint");
            tbody.innerHTML = "";
            var ve = user.reData;
            totalpage =  user.pagination.totalPages;
            document.getElementById("totalpageshow").innerHTML = user.pagination.currentPage; 
            document.getElementById("totalenter").innerHTML = user.pagination.totalPages; 
            document.getElementById("totalRows").innerHTML = user.pagination.totalRows; 
            ve.forEach(element => {
              var row = document.createElement("tr");
              var td = 
                  "<th scope='row'>" + element.id + " </th>"
                  + "<th class='center'>"
                  + "<i class='fa fa-trash text-danger delete-icon' type='button' id='alert_demo_7' style='font-size:20px;margin-right:5px' data-da='" + element.id + "'></i>"
                  + "</th>"
                  + "<td>" + element.name + "</td>"
                  + "<td>" + element.image + "</td>"
                  + "<td>" + element.time + "</td>"
              ;
              row.innerHTML = td;

              tbody.appendChild(row);
              // pagenumber.innerHTML = page;
            });
          },

          error: function (xhr, status, error) {
            console.error('Failed to fetch data:', error);
          },
        });
      }

    function depostSubmit(){
      console.log(idd);
    }
      // Load data initially
      fetchData();
  
      // Reload data on search input change
      $('#form1').on('keyup', function () {
        fetchData();
      });
  
      // Reload data on date filter button click
      $('#filterButton').on('click', function () {
        fetchData();
      });
      $('#perviousP').on('click', function () {
        if(page > 1){
          page--;
          fetchData();
        }
      });
      $('#nextP').on('click', function () {

        if(page < totalpage){
          page++;
          fetchData();
        }
      });
  </script>
  <script>
