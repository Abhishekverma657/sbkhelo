    <!-- deltet modal -->

    
<script>
  function newuser(){
    $.ajax({
      url: '/AllgameStart', 
      type: 'POST',
      success: function (response) {
        const user =response;
        if (response.Qstatus == 1) {
          const ve = user.Redata;
          const table = document.getElementById("selfBonusT");
          table.innerHTML = "";

          ve.forEach((element) => {
              // Create a container for each user
              const row = document.createElement("tr");
              let td = `
              <td scope="row">${element.id}</td>
              <td>${element.name}</</td>
             <td> <input class="form-check-input"  ${(element.active == 0) ? '' : 'checked'} type="checkbox" style="font-size:1.5rem;" onclick="edit(this)" data-da="${element.id}" id="flexSwitchCheckDefault"></td>`;
            row.innerHTML = td;
              table.appendChild(row);
          });
      }

      }
    });
  }
  newuser();

  function addSelfD(){
    let amount = document.getElementById("addAmount").value;
    let AddBonus = document.getElementById("AddBonus").value;
    if(!amount || !AddBonus){
      swal("Error", "Both Aamount and Bonus limits are required.", "error");
      return;
    }
    const resData  ={
      amount,AddBonus
    };
    $.ajax({
      url : "addSelfDeposit",
      type : 'POST',
      contentType: 'application/json',
      data: JSON.stringify(resData),
      success: function (respona) {
        if(respona.Qstatus == 1){
          swal("Success", respona.message, "success");
          newuser();
        }else{
          swal("Error", respona.message, "error");

        }
      }
    });
  }

var on  ;
var idd ;
function edit(checkbox) {
      if(checkbox.checked){
        on = 1;
      } else {
        on = 0;
      }
    idd = checkbox.getAttribute("data-da");
    document.getElementById("sildid").value = idd;
    $('#myModal').modal('show');
    console.log(idd);   
}

function submt(){
    const sendD = {
        idd, on
    };
        $.ajax({
         type: "POST",
         url: "gameactiveA",
         contentType: 'application/json',
         data: JSON.stringify(sendD),
         success:function(response){
             if(response.Qstatus == 1){
                 console.log(response.Qstatus);
                    swal("Success", response.message, "success");
                }else{
                    swal("Error", response.message, "error");
             }
         }
    })
    $('#myModal').modal('hide');
}
</script>

