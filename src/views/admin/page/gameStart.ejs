<%- include('../layout/header') %>
<style>
    /* Table styling for alignment */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    td {
        text-align: center;
        vertical-align: middle;
        padding: 10px;
    }

    /* Switch button styling */
    .form-check-input {
        position: relative;
        width: 60px;
        height: 30px;
        -webkit-appearance: none;
        appearance: none;
        background-color: #ddd;
        border-radius: 30px;
        outline: none;
        cursor: pointer;
        transition: background-color 0.3s ease;
        border: none; /* Remove default border */
    }

    .form-check-input:checked {
        background-color: #4caf50;
    }

    /* The circle inside the switch */
    .form-check-input::before {
        content: '';
        position: absolute;
        top: 5px;
        left: 5px;
        width: 20px;
        height: 20px;
        background-color: #fff;
        border-radius: 50%;
        transition: transform 0.3s ease;
    }

    .form-check-input:checked::before {
        transform: translateX(30px);
    }
</style>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<div class="card pt-5">

</div>
<div class="card">
    <div class="card-header">
      <div class="card-title">Game Pool</div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered">
          <thead>
            <tr>
              <th>#</th>
              <th>Game Name</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="selfBonusT">
            <!-- backend -->
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="de">
    <div id="myModal" class="modal fade">
      <div class="modal-dialog modal-confirm">
        <div class="modal-content">
        <i class="bi bi-exclamation-circle text-danger" style="font-size:2rem"></i>
          <div class="modal-body">
            <p>Do you really want to Game On/Off ? This process cannot be undone.</p>
          </div>
          <form action="controller/controller.php" method="post">
          <div class="modal-footer">
            <input type="hidden" name="iddd" id="sildid">
            <button type="button" class="btn btn-info" data-dismiss="modal">Cancel</button>
            <button type="button" onclick="submt()" name="gameactive1" class="btn btn-danger">Change</button>
          </div>
