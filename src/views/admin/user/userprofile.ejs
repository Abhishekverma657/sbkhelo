<%- include('../layout/header') %>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<div class="pt-4 m-3"></div>
<div class="pt-4 m-3"></div>

<div class="row m-3 justify-content-around">
    <!-- Left Section: Profile Card -->
    <div class="col-md-5">
        <div class="card card-profile">
            <!-- Card Header -->
            <div class="card-header" style="background-image: url('assets/img/blogpost.jpg')">
                <div class="profile-picture">
                    <div class="avatar avatar-xl">
                        <img src="/assets/img/profile.jpg" alt="Profile Picture" class="avatar-img rounded-circle" />
                    </div>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body">
                <div class="user-profile text-center">
                    <div class="d-flex justify-content-between"><p>Name : </p><p><%= user.username %></p></div>
                    <div class="d-flex justify-content-between"><p>Mobile : </p><p><%= user.mobile %></p></div>
                    <div class="d-flex justify-content-between"><p>Wallet : </p><p>₹<%= user.wallet || 0 %></p></div>
                    <div class="d-flex justify-content-between"><p>Win Wallet : </p><p>₹<%= user.winWallet || 0 %></p></div>
                    <div class="d-flex justify-content-between"><p>Total Win : </p><p>₹<%= user.winAmount || 0 %></p></div>
                    <div class="d-flex justify-content-between"><p>Total Lose : </p><p>₹<%= user.LoseAmount || 0 %></p></div>
                    <div class="d-flex justify-content-between"><p>Join Date : </p><p><%= user.time %></p></div>
                </div>
            </div>

            
        </div>
    </div>

    <!-- Right Section: Stats and Date Filter -->
    <div class="col-md-7">
        <!-- Date Filter Card -->
         <!-- Date Filters -->
  <div class="card-body">
    <div class="row mb-3 align-items-end">
      <div class="col-md-4">
        <label for="startDate" class="form-label">Start Date</label>
        <input type="date" id="startDate" class="form-control" />
      </div>
      <div class="col-md-4">
        <label for="endDate" class="form-label">End Date</label>
        <input type="date" id="endDate" class="form-control" />
      </div>
      <div class="col-md-4">
        <button type="button" onclick="DataSave()" id="filterButton" class="btn btn-success w-100">
          <i class="fas fa-filter"></i> Filter
        </button>
      </div>
    </div>
        <div class="card card-stats card-round shadow-sm" style="overflow: hidden;">
            <!-- Scrollable Header Container -->
            <div class="d-flex align-items-center" style="width: 100%; overflow-x: auto; white-space: nowrap;margin-left: 10px;margin-right: 10px;">
                <p class="cursor m-2 text-primary" onclick="window.location.href='/super/user/<%= user.id %>'">Dashboard</p>
                <p class="cursor m-2" onclick="window.location.href='/super/user-passbook/<%= user.id %>'">commission</p>
                <p class="cursor m-2" onclick="window.location.href='/super/user-deposit/<%= user.id %>'">Admin Deposit</p>
                  <p class="cursor m-2" onclick="window.location.href='/super/user-with/<%= user.id %>'">Withdrawals</p>
                <p class="cursor m-2" onclick="window.location.href='/super/user-trade/<%= user.id %>'">Trade</p>
                <p class="cursor m-2" onclick="window.location.href='/super/user-commit/<%= user.id %>'">Community</p>
                <p class="cursor m-2" onclick="window.location.href='/super/user-update/<%= user.id %>'">Update user data</p>
                 <!-- <p class="cursor m-2" onclick="window.location.href='/super/user-bank/<%= user.id %>'">Update Bank</p> -->
            </div>
        </div>
        
        <!-- Stats Row -->
        <div class="row">
            <!-- Revenue Card -->
            <div class="col-sm-6 mb-3">
                <div class="card card-stats card-round shadow-sm">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-4">
                                <div class="icon-big text-center text-success">
                                    <i class="fas fa-wallet fa-2x"></i>
                                </div>
                            </div>
                            <div class="col-8">
                                <div class="numbers">
                                    <p class="card-category mb-1">Bet Amount</p>
                                    <h4 class="card-title">₹<span id="betamount">londing...</span></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Profit Card -->
            <div class="col-sm-6 mb-3">
                <div class="card card-stats card-round shadow-sm">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-4">
                                <div class="icon-big text-center text-info">
                                    <i class="fas fa-chart-line fa-2x"></i>
                                </div>
                            </div>
                            <div class="col-8">
                                <div class="numbers">
                                    <p class="card-category mb-1">Bet Commission</p>
                                    <h4 class="card-title">₹<span id="commission">londing...</span></h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<!-- AJAX Script for Profile Update -->
<script>
  const userid = '<%= user.id %>';
  const promocode = '<%= user.promocode %>';
  console.log(userid , "userod");
  
    function DataSave() {
        const requestData = { userid, promocode };
        const startDate = $('#startDate').val();
        const endDate = $('#endDate').val();
        if (startDate && endDate) {
          requestData.startdate = startDate;
          requestData.enddate = endDate;
        }
        $.ajax({
            url: '/userPorfildashborad',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(requestData),
            success: function (response) {
                if (response.status == 1) {
                    document.getElementById("betamount").innerHTML = response.datacomm.bet_amount;
                    document.getElementById("commission").innerHTML = response.datacomm.amount;
                } else {
                    swal(response.message, { buttons: { confirm: { className: "btn btn-danger" } } });
                }
            },
        });
    }

    window.onload = function() {
        DataSave();
    };
   
</script>

<%- include('../layout/footer') %>
