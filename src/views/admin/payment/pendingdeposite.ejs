  <script>
    let page = 1;
    let totalpage = 1;

      function fetchData() {
        const requestData = {
          item: $('#form1').val().trim(),
          page : page,
          status : 1,
          tableName : 'auto_rechage',
        };
        const startDate = $('#startDate').val();
        const endDate = $('#endDate').val();
        if (startDate && endDate) {
          requestData.startdate = startDate;
          requestData.enddate = endDate;
        }

        // Make AJAX request to fetch data
        $.ajax({
          url: '/depositeP', // Your Node.js API endpoint
          type: 'POST',
          contentType: 'application/json',
          data: JSON.stringify(requestData),
          success: function (response) {
            const user =response; // Corrected this line from 'respona' to 'response'
            var tbody = document.getElementById("tableprint");
            tbody.innerHTML = "";
            var ve = user.reData;
            totalpage =  user.pagination.totalPages;
            document.getElementById("totalpageshow").innerHTML = user.pagination.currentPage; 
            document.getElementById("totalenter").innerHTML = user.pagination.totalPages; 
            document.getElementById("totalRows").innerHTML = user.pagination.totalRows; 
            document.getElementById("totalPending").innerHTML = user.DesPending; 
            document.getElementById("totalSucess").innerHTML = user.DesSuccess; 
            document.getElementById("totalReject").innerHTML = user.DesReject; 
            document.getElementById("totalGetway").innerHTML = user.getAmount; 
            ve.forEach(element => {
              var row = document.createElement("tr");
              var td = 
                  "<th scope='row'>" + element.id + " </th>"
                  + "<th>"
                  + "<i class='fa fa-trash text-danger delete-icon' type='button' id='alert_demo_7' style='font-size:20px;margin-right:5px' data-da='" + element.id + "'></i>"
                  + "<i class='fa fa-circle-check text-success' style='font-size:20px;margin-left:5px;' data-bs-toggle='modal' data-idd='" + element.id + "' data-upi='"+ element.transtion+"' onclick='action(this)' data-bs-target='#staticBackdrop'></i>"
                  + "</th>"
                  + "<td>" + element.userid + "</td>"
                  + "<td><a href='/user/"+element.id+"'>" + element.mobile + "</a></td>"
                  + "<td>" + element.amount + "</td>"
                  + "<td>" + element.userwallet + "</td>"
                  + "<td>" + element.time + "</td>"
              ;
              row.innerHTML = td;

              tbody.appendChild(row);
              // pagenumber.innerHTML = page;
            });
          },

          error: function (xhr, status, error) {
            console.error('Failed to fetch data:', error);
          },
        });
      }
  
    var idd;
    function action(par) {
      idd = par.getAttribute("data-idd"); // Correct method name
      var transtion = par.getAttribute("data-upi"); // Correct method name
      document.getElementById("upiidshow").innerHTML = transtion;
      console.log(idd + transtion);
    }
    function depostSubmit(){
      console.log(idd);
    }
      // Load data initially
      fetchData();
  
      // Reload data on search input change
      $('#form1').on('keyup', function () {
        fetchData();
      });
  
      // Reload data on date filter button click
      $('#filterButton').on('click', function () {
        fetchData();
      });
      $('#perviousP').on('click', function () {
        if(page > 1){
          page--;
          fetchData();
        }
      });
      $('#nextP').on('click', function () {

        if(page < totalpage){
          page++;
          fetchData();
        }
      });
  </script>
  <script>
    $(document).on('click', '.delete-icon', function (e) {
    const recordsIdd = $(this).data('da');
    const requestData1 = {
      tableName : 'auto_rechage',
      tableidd: recordsIdd,
    };
    swal({
        title: "Are you sure?",
        text: "You won't be able to revert this!",
        type: "warning",
        buttons: {
            confirm: {
                text: "Yes, delete it!",
                className: "btn btn-success",
            },
            cancel: {
                visible: true,
                className: "btn btn-danger",
            },
        },
    }).then((Delete) => {
        if (Delete) {
          $.ajax({
            url: '/recordsDeleted', // Your Node.js API endpoint
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(requestData1),
            success: function (response) {
              const user =response;
              if(response.status == 1){
                swal({
                  title: "Deleted!",
                  text: response.message,
                  type: "success",
                  buttons: {
                    confirm: {
                      className: "btn btn-success",
                    },
                  },
                  });
                  fetchData();
              }else{
                swal({
                  title: "Sever Error!",
                  text: response.message,
                  type: "info",
                });
              }
            }
          });
            
        } else {
            swal.close();
        }
    });
});

  </script>
<script>
  document.getElementById('exportButton').addEventListener('click', function () {
    // Trigger export with status = 1
    fetch('/depostipendingEXP', {
      method: 'POST', // Use POST to send data
      headers: {
        'Content-Type': 'application/json', // Set content type
      },
      body: JSON.stringify({ status: 0 }), // Send status = 1
    })
      .then((response) => {
        if (response.ok) {
          return response.blob(); // Expect a file download
        } else {
          throw new Error('Failed to export data');
        }
      })
      .then((blob) => {
        // Create a download link and click it
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'exported_Pending_Deposit.csv'; // Filename
        document.body.appendChild(a);
        a.click();
        a.remove();
        window.URL.revokeObjectURL(url);
      })
      .catch((error) => {
        console.error(error);
        alert('Error exporting data');
      });
  });
</script>


