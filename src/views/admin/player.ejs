  <script>

function SubmitAction() {
  let name = document.getElementById('user_name').value.trim();
  let mobile = document.getElementById('user_mobile').value.trim();
  let password = document.getElementById('user_password').value.trim();
  let type = document.getElementById('user_type').value.trim();
  let email = document.getElementById('email').value.trim();
  let commission = document.getElementById('user_commission').value.trim();

  if (!name || !mobile || !password || !type || !commission) {
    swal({
      title: "Missing Fields!",
      text: "Please fill all the fields.",
      icon: "warning",
    });
    return;
  }

  // Create the payload object
  const payload = {
    name: name,
    mobile: mobile,
    password: password,
    type: type,
    commission: commission,
    email
  };

  // Call the API using fetch
  fetch("/add_user", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(payload)
  })
  .then(response => response.json())
  .then(data => {
    if (data.status === 1 ) {
      fetchData();
      swal({
        title: "Success!",
        text: "User added successfully.",
        icon: "success",
      });
    } else {
      swal({
        title: "Error!",
        text: data.message || "Something went wrong.",
        icon: "error",
      });
    }
  })
  .catch(error => {
    console.error("API Error:", error);
    swal({
      title: "Server Error!",
      text: "Could not connect to server.",
      icon: "error",
    });
  });
}

function setUserId(element) {
  const userId = element.getAttribute('data-id');
  document.getElementById('searchId').value = userId;
}

    let page = 1;
    let totalpage = 1;

    function fetchData() {

      const userType = Number($('#userType').val());
      const requestData = {
        item: $('#form1').val().trim(),
        page: page,
        userType
      };

      // Add date filters only if both startDate and endDate are provided
      const startDate = $('#startDate').val();
      const endDate = $('#endDate').val();
      if (startDate && endDate) {
        requestData.startdate = startDate;
        requestData.enddate = endDate;
      }

      // Make AJAX request to fetch data
      $.ajax({
        url: '/allusersAPi', // Your Node.js API endpoint
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(requestData),
        success: function (response) {
          const user = response; // Corrected this line from 'respona' to 'response'
          var tbody = document.getElementById("tableprint");
          tbody.innerHTML = "";
          var ve = user.data;
          totalpage = user.pagination.totalPages;
          document.getElementById("totalpageshow").innerHTML = user.pagination.currentPage;
          document.getElementById("totalenter").innerHTML = user.pagination.totalPages;
          document.getElementById("totalRows").innerHTML = user.pagination.totalRows;
          ve.forEach(element => {
            var row = document.createElement("tr");
            var td =
              "<th scope='row'>" + element.id + " </th>"
              + "<th style='width: 100px;'>"
              + "<i class='fa fa-trash text-danger delete-icon' type='button' id='alert_demo_7' style='font-size:20px;margin-right:5px;' data-da='" + element.id + "'></i>" 
              + "<i class='fa fa-address-card' style='font-size:20px;margin-left:5px;margin-left:40px' onclick=\"window.location.href='user/' + " + element.id + "\"></i>"
              + "</th>"
          + "<th>"
+ "<i data-bs-toggle='modal' data-bs-target='#blockdepost' data-id='" + element.id + "' class='fa-solid fa-money-bill-wave text-success' onclick='setUserId(this)'></i>"
+ "</th>"


              + "<td>" + element.name + "</td>"
              + "<td><a href='/super/user/" + element.id + "'>" + element.mobile + "</a></td>"
              + "<td>" + element.email + "</td>"
              + "<td>" + element.uperline + "</td>"
              + "<td>" + element.admin_uperline + "</td>"
              + "<td>" + element.wallet + "</td>"
              + "<td>" + element.winamount + "</td>"
              + "<td>" + element.commission1 + "</td>"
              + "<td>" + element.totalrech + "</td>"
              + "<td>" + element.totalwith + "</td>"
              + "<td>" + element.totalwin + "</td>"
              + "<td>" + element.totalBet + "</td>"
              // + "<td>" + element.spinlimit + "</td>"
              + "<td>" + element.block + "</td>"
              + "<td>" + element.Otp + "</td>"
            + "<td>" + element.Commission+ "</td>"

              + "<td>" + (
                element.login_type == 3 ? 'Admin' :
                  element.login_type == 2 ? 'Agent' :
                    'User'
              ) + "</td>"

              + "<td>" + element.joindate + "</td>";
            ;
            row.innerHTML = td;

            tbody.appendChild(row);
            // pagenumber.innerHTML = page;
          });
        },

        error: function (xhr, status, error) {
          console.error('Failed to fetch data:', error);
        },
      });
    }



    // Load data initially
    fetchData();

    // Reload data on search input change
    $('#form1').on('keyup', function () {
      fetchData();
    });

    // Reload data on date filter button click
    $('#filterButton').on('click', function () {
      fetchData();
    });
    $('#perviousP').on('click', function () {
      if (page > 1) {
        page--;
        fetchData();
      }
    });
    $('#nextP').on('click', function () {

      if (page < totalpage) {
        page++;
        fetchData();
      }
    });
  </script>
