  <script>
    document.getElementById('exportButton').addEventListener('click', function () {
      // Trigger export
      fetch('/exportDataApi', {
        method: 'GET',
      })
        .then((response) => {
          if (response.ok) {
            return response.blob(); // Expect a file download
          } else {
            throw new Error('Failed to export data');
          }
        })
        .then((blob) => {
          // Create a download link and click it
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'exported_data.csv'; // Filename
          document.body.appendChild(a);
          a.click();
          a.remove();
          window.URL.revokeObjectURL(url);
        })
        .catch((error) => {
          console.error(error);
          alert('Error exporting data');
        });
    });
  </script>


<script>
async function MakePayment() {
  let reschAdd = document.getElementById("reschAdd").value;
  let amountF = document.getElementById("amountF").value;
  let searchId = document.getElementById("searchId").value;
  let NotificationsOn = document.getElementById("NotificationsOn").value;
  let nottext = document.getElementById("nottext").value;

  if (!reschAdd || !amountF || !searchId) {
    swal({
      title: "Parameter Missing!",
      text: "thanks",
      type: "error",
    });
    return;
  }

  if (NotificationsOn == 2 && !nottext) {
    swal({
      title: "Parameter Missing!",
      text: "thank",
      type: "error",
    });
    return;
  }

  const sendData = {
    reschAdd,
    amountF,
    searchId,
    NotificationsOn,
    nottext
  };

  try {
    const response = await fetch("makePayment1", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(sendData),
    });

    const respona = await response.json();

    if (respona.Qstatus == 1) {
      document.getElementById("amountF").value = "";
      document.getElementById("searchId").value = "";
      document.getElementById("nottext").value = "";
      // close modal
      // const closeButton = document.getElementById("closeBtn1");
      // if (closeButton) closeButton.click();
      // showSuccessToast(respona.message);
      hideDepositPopup();
      fetchData();
    } else {
      // showSuccessToast(respona.message);
      fetchData();
      // hidemakepayment(1);
    }
  } catch (error) {
    console.error("Error:", error);
    // showSuccessToast(respona.message);
    fetchData();
    // hidemakepayment(1);
  }
}

function hideDepositPopup() {
  console.log("ADfg");
  
  const modalEl = document.getElementById('blockdepost');
  const modal = bootstrap.Modal.getInstance(modalEl); // get the current modal instance
  if (modal) {
    modal.hide(); // close it
  }
}


function showSuccessToast(value) {
        document.getElementById("showerror").innerHTML = value;
        const toast = document.getElementById('successToast');
        toast.classList.remove('hidden');
        setTimeout(() => {
          hideSuccessToast();
        }, 3000);
      }
</script>

