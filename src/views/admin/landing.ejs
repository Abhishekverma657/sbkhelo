    <!-- Mobile nav script -->
    <script>
      let limit = 170;
      const navToggle = document.getElementById('navToggle');
      const mobileNav = document.getElementById('mobileNav');
      navToggle.addEventListener('click', () => {
        mobileNav.classList.toggle('hidden');
      });

      // OPTIONAL: Smooth section scroll
      document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            e.preventDefault();
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
            mobileNav.classList.add('hidden');
          }
        });
      });
    </script>
    <script>
      async function fetchResults() {
        try {
          const res = await fetch("/backresult", {
            method: "POST", // ✅ change to POST
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              // ✅ if API needs parameters, put here
              limit: limit
            }),
          });

          const data = await res.json();

          if (data.status === 1 && Array.isArray(data.data)) {
            document.getElementById("gameid").innerHTML = data.data[0].gameid;
            const latest = data.data.slice(0, limit); // latest 5
            const tbody = document.getElementById("results-body");

            tbody.innerHTML = latest
              .map((item, index) => {
                // ✅ format date
                const time = new Date(item.time).toLocaleString("en-IN", {
                  day: "2-digit",
                  month: "2-digit",
                  year: "numeric",
                  hour: "2-digit",
                  minute: "2-digit",
                  second: "2-digit",
                  hour12: true,
                });

                return `
              <tr class="${index % 2 === 0
                    ? "hover:bg-green-50"
                    : "bg-green-50 hover:bg-green-100"
                  }">
                <td class="px-4 py-2">${index + 1}</td>
                <td class="px-4 py-2 font-bold text-green-600">${item.result}</td>
                <td class="px-4 py-2">
                  <span class="bg-yellow-200 text-green-800 rounded px-3 py-1 font-semibold">${item.xvalue}x</span>
                </td>
                <td class="px-4 py-2">${time}</td>
              </tr>`;
              })
              .join("");
          }
        } catch (err) {
          console.error("Error fetching results:", err);
        }
      }

      // ✅ first load
      fetchResults();

      function moreload() {
        limit += 10;
        fetchResults();
      }

    </script>


    <script>
      let slotDuration = 300;       // total round duration in seconds
      let bettingCloseTime = 5;    // last X seconds betting closed
      let delay = 9000;           // 10s delay like your C# code

      function updateTimer() {
        // current time in ms (with delay)
        let nowMs = Date.now() - delay;
        let cycleMs = slotDuration * 1000;

        // modulus to stay inside current round
        let mod = nowMs % cycleMs;
        if (mod < 0) mod += cycleMs;

        // remaining time in sec
        let remaining = (cycleMs - mod) / 1000;
        let remainingSeconds = Math.ceil(remaining);

        // betting allowed?
        let isBettingAllowed = remaining > bettingCloseTime;

        // update UI
        document.getElementById("timer").textContent = remainingSeconds;
        if (remainingSeconds < 2) {
          fetchResults();
        }

      }

      // run once immediately
      updateTimer();

      // update every 1 sec
      setInterval(updateTimer, 1000);
    </script>

