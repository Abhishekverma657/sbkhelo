            <li class="nav-item">
              <a href="/superadmin" class="nav-link">
                <i class="fas fa-sign-out-alt"></i>
                <p>Logout</p>
              </a>
            </li>

          </ul>
        </div>
      </div>

      <script>

        // ✅ Highlight active page based on current URL
        document.querySelectorAll(".nav-link").forEach(link => {
          if (link.href === window.location.href) {
            link.classList.add("active");
            const parentCollapse = link.closest(".collapse");
            if (parentCollapse) {
              parentCollapse.classList.add("show");
              const parentTrigger = parentCollapse.previousElementSibling;
              if (parentTrigger) parentTrigger.classList.remove("collapsed");
            }
          }
        });
      </script>

      <style>
        /* ✅ Active link style */
        .nav-link.active {
          background: #2b2b2b;
          color: #986868 !important;
          border-radius: 6px;
        }

        .nav-link.active i {
          color: #00d1b2;
        }
      </style>

    </div>
    <!-- End Sidebar -->

    <div class="main-panel">
      <div class="main-header">
