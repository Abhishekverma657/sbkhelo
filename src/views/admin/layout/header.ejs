        <style>
          /* Make navbar relative so center works */
          .navbar-header {
            position: relative;
            min-height: 70px;
          }

          /* Center timer + background */
          .navbar-header .header-time {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);

            background: #111827;
            /* dark bg */
            color: #ffffff;
            padding: 6px 16px;
            border-radius: 25px;
            font-weight: 600;
            font-size: 15px;
            gap: 6px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
          }

          /* Clock icon size */
          .navbar-header .header-time i {
            font-size: 16px;
          }
        </style>


        <!-- Navbar Header -->
        <nav class="navbar navbar-header navbar-header-transparent navbar-expand-lg border-bottom">
          
       <button class="btn btn-outline-primary btn-sm" onclick="openFullscreen()">Go Fullscreen</button>
          <!-- <div class="container-fluid d-flex align-items-center"> -->
