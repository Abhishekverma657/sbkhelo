                <div class="card table-card">
                    <div class="card-header bg-white border-bottom">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1 fw-semibold">Withdrawls History</h5>
                                <p class="mb-0 text-muted small">Recent payment transactions</p>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-light icon-btn" title="Refresh">
                                    <i class="fas fa-refresh"></i>
                                </button>
                                <button class="btn btn-light icon-btn" title="Download">
                                    <i class="fas fa-download"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Payment Details</th>
                                        <th class="text-end">User ID</th>
                                        <th class="text-end">User Mobile</th>
                                        <th class="text-end">Amount</th>
                                        <th class="text-end">Sender</th>
                                        <th class="text-end">Time</th>
                                        <th class="text-end">Status</th>
                                    </tr>
                                </thead>
                                <tbody id="tableDepsit1">
                                    <tr>
                                        <td colspan="7" class="text-center py-5">
                                            <i class="fas fa-spinner fa-spin loading-spinner fs-2 mb-2"></i>
                                            <p class="text-muted mb-0">Loading transactions...</p>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- Bootstrap 5 JS Bundle -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            // Enhanced date handling
            const today = new Date();
            const todayFormatted = today.toISOString().split('T')[0];
            const tomorrow = new Date();
            tomorrow.setDate(today.getDate() + 1);
            const tomorrowFormatted = tomorrow.toISOString().split('T')[0];
            document.getElementById("todaydate").innerHTML = todayFormatted;
            // Set default dates
            document.getElementById('startDate').value = todayFormatted;
            document.getElementById('endDate').value = tomorrowFormatted;

            // Loading state management
            function setLoadingState(isLoading) {
                const button = document.getElementById('filterButton');
                if (isLoading) {
                    button.disabled = true;
                    button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Loading...</span>';
                    button.classList.add('opacity-75');
                } else {
                    button.disabled = false;
                    button.innerHTML = '<i class="fas fa-filter me-2"></i>Filter';
                    button.classList.remove('opacity-75');
                }
            }

            function onload() {
                setLoadingState(true);

                const requestData = {
                    startDate: todayFormatted,
                    endDate: tomorrowFormatted
                };

                const startDate1 = $('#startDate').val();
                const endDate1 = $('#endDate').val();

                if (startDate1 && endDate1) {
                    requestData.startDate = startDate1;
                    requestData.endDate = endDate1;
                }

                $.ajax({
                    url: '/AdminDashbord',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(requestData),
                    success: function (response) {
                        if (response.Qstatus == 1) {
                            // Animate number updates
                            animateValue("betamount", 0, parseFloat(response.betamount) || 0);
                            animateValue("betting", 0, parseInt(response.betting) || 0);
                            animateValue("betwin", 0, parseFloat(response.betwin) || 0);
                            animateValue("user", 0, parseInt(response.user) || 0);
                            animateValue("agent_total_amount", 0, parseFloat(response.agent_total_amount) || 0);
                            animateValue("user_total_amount", 0, parseFloat(response.user_total_amount) || 0);
                            animateValue("pool", 0, parseFloat(response.pool) || 0);
                            animateValue("admin_comm", 0, parseFloat(response.admin_comm) || 0);
                            animateValue("take", 0, parseFloat(response.take) || 0);
                            animateValue("betcommission", 0, parseFloat(response.commission) || 0);
                            animateValue("agnet", 0, parseInt(response.agnet) || 0);

                            animateValue("DepositS", 0, parseInt(response.add_recharge) || 0);
                            animateValue("Depositp", 0, parseInt(response.cut_recharge) || 0);
                            animateValue("admin_total", 0, parseInt(response.admin_total) || 0);
                            animateValue("agenttotal", 0, parseInt(response.agenttotal) || 0);

                            animateValue("withdrawlp", 0, parseInt(response.withdrawl_p) || 0);
                            animateValue("withdrawlS", 0, parseInt(response.withdrawl_S) || 0);

                            const profit = (parseFloat(response.betamount) || 0) - (parseFloat(response.betwin) || 0);
                            animateValue("totalprofit", 0, (parseFloat(profit) - parseFloat(response.commission)) || 0);
                            animateValue("profiles", 0, profit);
                        } else {
                            showError("Failed to load dashboard data");
                        }
                    },
                    error: function () {
                        showError("Network error occurred");
                    },
                    complete: function () {
                        setLoadingState(false);
                    }
                });
            }

            // Number animation function
            function animateValue(id, start, end) {
                const element = document.getElementById(id);
                const duration = 1000; // 1 second
                const startTime = performance.now();

                function updateValue(currentTime) {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);

                    const current = start + (end - start) * progress;

                    if (id === 'user' || id === 'betting' || id === "agnet") {
                        element.textContent = Math.floor(current).toLocaleString();
                    } else {
                        element.textContent = '₹ ' + current.toLocaleString('en-IN', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        });
                    }

                    if (progress < 1) {
                        requestAnimationFrame(updateValue);
                    }
                }

                requestAnimationFrame(updateValue);
            }

            // Enhanced transaction loading
            function newDepost() {
                $.ajax({
                    url: '/newDepostiDashbord',
                    type: 'POST',
                    success: function (response) {
                        if (response.Qstatus == 1) {
                            const transactions = response.reData || [];
                            const table = document.getElementById("tableDepsit");
                            table.innerHTML = "";

                            if (transactions.length === 0) {
                                table.innerHTML = `
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="fas fa-inbox fs-2 mb-2"></i>
                                        <p class="mb-0">No transactions found</p>
                                    </td>
                                </tr>
                            `;
                                return;
                            }

                            transactions.forEach((element) => {
                                const row = document.createElement("tr");
                                row.className = "hover-row";

                                const statusConfig = {
                                    1: { color: 'warning', text: 'Pending', icon: 'fa-clock' },
                                    2: { color: 'success', text: 'Success', icon: 'fa-check' },
                                    default: { color: 'danger', text: 'Rejected', icon: 'fa-times' }
                                };

                                const status = statusConfig[element.status] || statusConfig.default;

                                row.innerHTML = `
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="icon-circle bg-${status.color} bg-opacity-10 me-3">
                                            <i class="fas ${status.icon} text-${status.color}"></i>
                                        </div>
                                        <div>
                                            <div class="fw-medium text-dark">Payment #${element.id || "00"}</div>
                                            <div class="small text-muted">Transaction ID</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end">${element.userid || "N/A"}</td>
                                <td class="text-end">${element.mobile || "N/A"}</td>
                                <td class="text-end fw-bold">₹${parseFloat(element.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
                                <td class="text-end">${element.admin_id || "N/A"}</td>
                                <td class="text-end">${element.time || "N/A"}</td>
                                <td class="text-end">
                                    <span class="badge bg-${status.color} bg-opacity-10 text-${status.color} badge-status">
                                        ${status.text}
                                    </span>
                                </td>
                            `;

                                table.appendChild(row);
                            });
                        }
                    },
                    error: function () {
                        const table = document.getElementById("tableDepsit");
                        table.innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-5 text-danger">
                                <i class="fas fa-exclamation-triangle fs-2 mb-2"></i>
                                <p class="mb-0">Error loading transactions</p>
                            </td>
                        </tr>
                    `;
                    }
                });
            }
            // Enhanced transaction loading
            function newDepost1() {
                $.ajax({
                    url: '/newWithdrwalsDashbord',
                    type: 'POST',
                    success: function (response) {
                        if (response.Qstatus == 1) {
                            const transactions = response.reData || [];
                            const table = document.getElementById("tableDepsit1");
                            table.innerHTML = "";

                            if (transactions.length === 0) {
                                table.innerHTML = `
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <i class="fas fa-inbox fs-2 mb-2"></i>
                                        <p class="mb-0">No transactions found</p>
                                    </td>
                                </tr>
                            `;
                                return;
                            }

                            transactions.forEach((element) => {
                                const row = document.createElement("tr");
                                row.className = "hover-row";

                                const statusConfig = {
                                    1: { color: 'warning', text: 'Pending', icon: 'fa-clock' },
                                    2: { color: 'success', text: 'Success', icon: 'fa-check' },
                                    3: { color: 'dager', text: 'Success', icon: 'fa-check' },
                                    default: { color: 'danger', text: 'Rejected', icon: 'fa-times' }
                                };

                                const status = statusConfig[element.status] || statusConfig.default;

                                row.innerHTML = `
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="icon-circle bg-${status.color} bg-opacity-10 me-3">
                                            <i class="fas ${status.icon} text-${status.color}"></i>
                                        </div>
                                        <div>
                                            <div class="fw-medium text-dark">Payment #${element.id || "00"}</div>
                                            <div class="small text-muted">Transaction ID</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-end">${element.userid || "N/A"}</td>
                                <td class="text-end">${element.mobile || "N/A"}</td>
                                <td class="text-end fw-bold">₹${parseFloat(element.amount || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 })}</td>
                                <td class="text-end">${element.admin_id || "N/A"}</td>
                                <td class="text-end">${element.time || "N/A"}</td>
                                <td class="text-end">
                                    <span class="badge bg-${status.color} bg-opacity-10 text-${status.color} badge-status">
                                        ${status.text}
                                    </span>
                                </td>
                            `;

                                table.appendChild(row);
                            });
                        }
                    },
                    error: function () {
                        const table = document.getElementById("tableDepsit");
                        table.innerHTML = `
                        <tr>
                            <td colspan="7" class="text-center py-5 text-danger">
                                <i class="fas fa-exclamation-triangle fs-2 mb-2"></i>
                                <p class="mb-0">Error loading transactions</p>
                            </td>
                        </tr>
                    `;
                    }
                });
            }

            // Error notification function
            function showError(message) {
                const toast = document.createElement('div');
                toast.className = 'position-fixed top-0 end-0 m-3 bg-danger text-white px-4 py-3 rounded shadow-lg';
                toast.style.zIndex = '9999';
                toast.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <span>${message}</span>
                </div>
            `;

                document.body.appendChild(toast);

                setTimeout(() => toast.remove(), 3000);
            }

            // DataSave function for filter button
            function DataSave() {
                onload();
            }

            // Initialize dashboard
            document.addEventListener('DOMContentLoaded', function () {
                onload();
                newDepost();
                newDepost1();
            });

            // Auto-refresh every 30 seconds
            setInterval(() => {
                onload();
                newDepost();
            }, 30000);
        </script>

        <style>
            .hover-row {
                transition: background-color 0.2s ease;
            }

            .hover-row:hover {
                background-color: #f8f9fa;
            }

            .icon-circle {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .opacity-75 {
                opacity: 0.75;
            }
        </style>

        <%- include('layout/footer') %>