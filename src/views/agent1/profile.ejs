<%- include('layout/header') %>

<div class="max-w-md mt-5 ml-5 cards rounded-2xl shadow-lg overflow-hidden border">

  <!-- Header -->
  <div class="flex flex-col items-center p-6 cards">
    <!-- Avatar -->
    <!-- <img src="https://via.placeholder.com/100" alt="Profile"
      class="w-24 h-24 rounded-full border-4 border-blue-500 shadow-md"> -->

    <!-- Name -->
    <h2 class="mt-4 text-xl font-semibold">John Doe</h2>
    <!-- Mobile -->
    <p class="text-sm">+91 9876543210</p>
  </div>

  <!-- Tabs -->
  <div class="flex border-b border-gray-300 dark:border-gray-700">
    <button onclick="openTab('profileTab')" id="profileBtn"
      class="flex-1 py-2 text-center font-medium bg-blue-600 text-white">Profile</button>
    <button onclick="openTab('passwordTab')" id="passwordBtn"
      class="flex-1 py-2 text-center font-medium hover:bg-gray-200 dark:hover:bg-gray-700 transition">Change Password</button>
  </div>

  <!-- Profile Tab -->
  <form id="profileTab" class="p-6 space-y-5">
    <!-- Name -->
    <div>
      <label class="block text-sm font-medium mb-1">Name</label>
      <input type="text" name="name" value="John Doe"
        class="w-full rounded-lg border border-gray-300 dark:border-gray-600 
               bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none 
               focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white">
    </div>

    <!-- Mobile -->
    <div>
      <label class="block text-sm font-medium mb-1">Mobile</label>
      <input type="tel" name="mobile" value="+91 9876543210"
        class="w-full rounded-lg border border-gray-300 dark:border-gray-600 
               bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none 
               focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white">
    </div>

    <!-- Save Button -->
    <div class="pt-3">
      <button type="submit"
        class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 
               text-white font-medium rounded-lg shadow-md transition">
        Save Changes
      </button>
    </div>
  </form>

  <!-- Password Tab -->
  <form id="passwordTab" class="p-6 space-y-5 hidden">
    <!-- Current Password -->
    <div>
      <label class="block text-sm font-medium mb-1">Current Password</label>
      <input type="password" name="current_password" placeholder="Enter current password"
        class="w-full rounded-lg border border-gray-300 dark:border-gray-600 
               bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none 
               focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white">
    </div>

    <!-- New Password -->
    <div>
      <label class="block text-sm font-medium mb-1">New Password</label>
      <input type="password" name="new_password" placeholder="Enter new password"
        class="w-full rounded-lg border border-gray-300 dark:border-gray-600 
               bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none 
               focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white">
    </div>

    <!-- Save Button -->
    <div class="pt-3">
      <button type="submit"
        class="w-full px-4 py-2 bg-green-600 hover:bg-green-700 
               text-white font-medium rounded-lg shadow-md transition">
        Update Password
      </button>
    </div>
  </form>
</div>

<script>
function openTab(tabId) {
  document.getElementById("profileTab").classList.add("hidden");
  document.getElementById("passwordTab").classList.add("hidden");

  document.getElementById(tabId).classList.remove("hidden");

  document.getElementById("profileBtn").classList.remove("bg-blue-600", "text-white");
  document.getElementById("passwordBtn").classList.remove("bg-blue-600", "text-white");

  if (tabId === "profileTab") {
    document.getElementById("profileBtn").classList.add("bg-blue-600", "text-white");
  } else {
    document.getElementById("passwordBtn").classList.add("bg-blue-600", "text-white");
  }
}
</script>



  <%- include('layout/footer') %>

    <!-- Block User Modal (JS version) -->
    <div id="blockUserModal"
      class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
      <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold">Block User</h3>
          <button onclick="closeBlockModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
            ✕
          </button>
        </div>
        <!-- Body -->
        <form id="blockUserForm" class="px-5 py-4 space-y-4">
          <div class="text-sm">
            <p class="font-medium">User</p>
            <p class="text-gray-600 dark:text-gray-300">John Doe · ID: 12345 (Active)</p>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Duration</label>
            <select name="duration"
              class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 dark:border-gray-600 dark:bg-gray-700">
              <option value="24h">Active</option>
              <option value="permanent">Block</option>
            </select>
          </div>
        </form>
        <!-- Footer -->
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
          <button onclick="closeBlockModal()"
            class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
            Cancel
          </button>
          <button type="button" onclick="blockUserAction()"
            class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
            Block
          </button>
        </div>
      </div>
    </div>

    <!-- Success Toast -->
    <div id="successToast"
      class="fixed top-5 right-5 z-50 hidden items-center gap-3 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg shadow-lg animate-slide-in">
      <i class="fa-solid fa-circle-check text-green-500 text-xl"></i>
      <span class="font-medium">this demo panel !</span>
      <button onclick="hideSuccessToast()" class="ml-2 text-green-700 hover:text-green-900 font-bold">
        &times;
      </button>
    </div>

    <!-- JS -->
    <script>
      function openBlockModal() {
        document.getElementById('blockUserModal').classList.remove('hidden');
      }
      function closeBlockModal() {
        document.getElementById('blockUserModal').classList.add('hidden');
      }
      function blockUserAction() {
        closeBlockModal();
        showSuccessToast();
      }
      function showSuccessToast() {
        const toast = document.getElementById('successToast');
        toast.classList.remove('hidden');
        setTimeout(() => {
          hideSuccessToast();
        }, 3000);
      }
      function hideSuccessToast() {
        document.getElementById('successToast').classList.add('hidden');
      }
    </script>

