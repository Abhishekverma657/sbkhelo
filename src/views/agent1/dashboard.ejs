<%- include('layout/header') %>


  <!-- Cards -->
  <div class="cards">
    <div class="card">
      <h3>Total Users</h3>
      <h2>12,345</h2>
    </div>
    <div class="card">
      <h3>Revenue</h3>
      <h2>$32,500</h2>
    </div>
    <div class="card">
      <h3>Active Sessions</h3>
      <h2>4,567</h2>
    </div>
    <div class="card">
      <h3>Conversion Rate</h3>
      <h2>3.5%</h2>
    </div>
  </div>

<div class=" p-4 ">
  <div class="card p-6 rounded-xl shadow flex-1 flex flex-col">
    <h3 class="text-lg font-bold mb-4">Recent Activity</h3>

    <!-- Filters -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-4">
      <input type="text" placeholder="Search by user or action" 
        class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

      <input type="date" style="color: #000000 !important;"
        class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

      <input type="date" style="color: #000000 !important;"
        class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

      <button 
        class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600">Filter</button>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto flex-1">
      <table class="min-w-full border border-gray-200">
        <thead class="bg-gray-200 sticky top-0">
          <tr style="color:#000000">
            <th class="p-3 border">User</th>
            <th class="p-3 border">Action</th>
            <th class="p-3 border">Date</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="p-3 border">John Doe</td><td class="p-3 border">Edited</td><td class="p-3 border">2024-04-20</td></tr>
          <tr><td class="p-3 border">Jane Smith</td><td class="p-3 border">Updated</td><td class="p-3 border">2024-04-19</td></tr>
          <tr><td class="p-3 border">Kevin Brown</td><td class="p-3 border">Created</td><td class="p-3 border">2024-04-19</td></tr>
          <tr><td class="p-3 border">Mary Johnson</td><td class="p-3 border">Deleted</td><td class="p-3 border">2024-04-18</td></tr>
        </tbody>
      </table>
    </div>
    <div class="flex justify-between mt-4">
      <div class="mt-4 space-x-2">
        <p class="">Total Pages : <span id="total_pages">0</span></p>
      </div>
      <div class=" mt-4 space-x-2">
        <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100" style="color: #000000 !important;"><</button>
        <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100" style="color: #000000 !important;">1</button>
        <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100" style="color: #000000 !important;">></button>
      </div>
    </div>
  </div>
</div>




  <%- include('layout/footer') %>

