  <%- include('layout/footer') %>

    <!-- Block User Modal (JS version) -->
    <div id="blockUserModal"
      class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
      <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold">Data Remove</h3>
          <button onclick="closeBlockModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
            ✕
          </button>
        </div>
        <!-- Body -->
        <form id="blockUserForm" class="px-5 py-4 space-y-4">
          <div class="text-sm justify-center">
            <p class="font-medium">Do you really want to delete these records? This process cannot be undone.</p>
          </div>
        </form>
        <!-- Footer -->
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
          <button onclick="closeBlockModal()"
            class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
            Cancel
          </button>
          <button type="button" onclick="blockUserAction()"
            class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
            Delete
          </button>
        </div>
      </div>
    </div>

    <!-- Block User Modal (JS version) -->
    <div id="blockUserModal1"
      class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
      <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold">Add Deposit</h3>
          <button onclick="closeBlockModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
            ✕
          </button>
        </div>
        <!-- Body -->
        <form id="blockUserForm" class="px-5 py-4 space-y-4">

          <div>
            <label class="block text-sm font-medium mb-1">Search User </label>
            <input type="number" name="amount" placeholder="Enter user id / mobile" class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
           focus:outline-none focus:ring focus:ring-blue-200
           dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Deposit Amount</label>
            <input type="number" name="amount" placeholder="Enter amount" class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 
           focus:outline-none focus:ring focus:ring-blue-200
           dark:border-gray-600 dark:bg-gray-700 dark:text-white" />
          </div>


          <div>
            <label class="block text-sm font-medium mb-1">Duration</label>
            <select name="duration"
              class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 dark:border-gray-600 dark:bg-gray-700">
              <option value="24h">Add Deposit</option>
              <option value="permanent">Cut Deposit</option>
            </select>
          </div>
          <!-- Reason -->
          <div>
            <label class="block text-sm font-medium mb-1">Reason</label>
            <textarea name="reason" rows="3" placeholder="Add a reason (optional)" class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2
                         focus:outline-none focus:ring focus:ring-red-200
                         dark:border-gray-600 dark:bg-gray-700"></textarea>
          </div>

          <!-- Notify toggle -->
          <label class="inline-flex items-center gap-2">
            <input type="checkbox" name="notify"
              class="h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-400 dark:border-gray-600">
            <span class="text-sm">Notify user by mail</span>
          </label>
        </form>
        <!-- Footer -->
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
          <button onclick="closedepositModal()"
            class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
            Cancel
          </button>
          <button type="button" onclick="blockUserAction()"
            class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
            Block
          </button>
        </div>
      </div>
    </div>

    <!-- Success Toast -->
    <div id="successToast"
      class="fixed top-5 right-5 z-50 hidden items-center gap-3 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg shadow-lg animate-slide-in">
      <i class="fa-solid fa-circle-check text-green-500 text-xl"></i>
      <span class="font-medium">this demo panel !</span>
      <button onclick="hideSuccessToast()" class="ml-2 text-green-700 hover:text-green-900 font-bold">
        &times;
      </button>
    </div>

    <!-- JS -->
    <script>
      function openBlockModal() {
        document.getElementById('blockUserModal').classList.remove('hidden');
      }
      function closeBlockModal() {
        document.getElementById('blockUserModal').classList.add('hidden');
      }
      function openAddDepositModal() {
        document.getElementById('blockUserModal1').classList.remove('hidden');
      }
      function closedepositModal() {
        document.getElementById('blockUserModal1').classList.add('hidden');
      }
      function blockUserAction() {
        closeBlockModal();
        showSuccessToast();
      }
      function showSuccessToast() {
        const toast = document.getElementById('successToast');
        toast.classList.remove('hidden');
        setTimeout(() => {
          hideSuccessToast();
        }, 3000);
      }
      function hideSuccessToast() {
        document.getElementById('successToast').classList.add('hidden');
      }
    </script>

