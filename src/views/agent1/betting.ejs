              <td class="p-3 border text-center">Lose</td>
              <td class="p-3 border text-center">2024-04-20</td>
            </tr>
            <tr>
              <td class="p-3 border text-center">4</td>
              <td class="p-3 border text-center">
                <div><i onclick="openBlockModal()"
                    class="fa-solid fa-trash ml-3 text-red-500"></i></div>
              </td>
              <td class="p-3 border text-center">Funtarget</td>
