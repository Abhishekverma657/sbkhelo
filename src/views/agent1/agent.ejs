<%- include('layout/header') %>


  <div class=" p-4 ">
    <div class="card p-6 rounded-xl shadow flex-1 flex flex-col">
      <h3 class="text-lg font-bold mb-4">Recent Activity</h3>

      <!-- Filters -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-4">
        <input type="text" placeholder="Search by user or action"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <input type="date" style="color: #000000 !important;"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <input type="date" style="color: #000000 !important;"
          class="border rounded-lg px-3 py-2 w-full focus:outline-none focus:ring focus:ring-blue-300">

        <button class="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600">Filter</button>
      </div>

      <!-- Table -->
      <div class="overflow-x-auto flex-1">
        <table class="min-w-full border border-gray-200">
          <thead class="bg-gray-200 sticky top-0">
            <tr style="color:#000000">
              <th class="p-3 border">#</th>
              <th class="p-3 border">Action</th>
              <th class="p-3 border">Name</th>
              <th class="p-3 border">Mobile</th>
              <th class="p-3 border">wallet</th>
              <th class="p-3 border">type</th>
              <th class="p-3 border">Block</th>
              <th class="p-3 border">Join date</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-3 border text-center">1</td>
              <td class="p-3 border text-center">
                <div><i class="fa-solid fa-edit"></i><i onclick="openBlockModal()"  class="fa-solid fa-ban ml-3 text-red-500"></i></div>
              </td>
              <td class="p-3 border text-center">John Doe</td>
              <td class="p-3 border text-center">9876543211</td>
              <td class="p-3 border text-center">2309.00</td>
              <td class="p-3 border text-center">Agent</td>
              <td class="p-3 border text-center">Active</td>
              <td class="p-3 border text-center">2024-04-20</td>
            </tr>
            
          </tbody>
        </table>
      </div>
      <div class="flex justify-between mt-4">
        <div class="mt-4 space-x-2">
          <p class="">Total Pages : <span id="total_pages">1</span></p>
        </div>
        <div class=" mt-4 space-x-2">
          <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100" style="color: #000000 !important;"><
            </button>
              <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100"
                style="color: #000000 !important;">1</button>
              <button class="px-3 py-1 rounded-lg border bg-white hover:bg-gray-100"
                style="color: #000000 !important;">></button>
        </div>
      </div>
    </div>
  </div>



  <%- include('layout/footer') %>

<!-- Block User Modal (JS version) -->
<div id="blockUserModal"
  class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
  <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
    <!-- Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold">Block User</h3>
      <button onclick="closeBlockModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
        ✕
      </button>
    </div>
    <!-- Body -->
    <form id="blockUserForm" class="px-5 py-4 space-y-4">
      <div class="text-sm">
        <p class="font-medium">User</p>
        <p class="text-gray-600 dark:text-gray-300">John Doe · ID: 12345 (Active)</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Duration</label>
        <select name="duration"
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 dark:border-gray-600 dark:bg-gray-700">
          <option value="24h">Active</option>
          <option value="permanent">Block</option>
        </select>
      </div>
    </form>
    <!-- Footer -->
    <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
      <button onclick="closeBlockModal()" class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
        Cancel
      </button>
      <button type="button" onclick="blockUserAction()" class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
        Block
      </button>
    </div>
  </div>
</div>

<!-- Success Toast -->
<div id="successToast"
  class="fixed top-5 right-5 z-50 hidden items-center gap-3 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg shadow-lg animate-slide-in">
  <i class="fa-solid fa-circle-check text-green-500 text-xl"></i>
  <span class="font-medium">this demo panel !</span>
  <button onclick="hideSuccessToast()" class="ml-2 text-green-700 hover:text-green-900 font-bold">
    &times;
  </button>
</div>

<!-- JS -->
<script>
function openBlockModal() {
  document.getElementById('blockUserModal').classList.remove('hidden');
}
function closeBlockModal() {
  document.getElementById('blockUserModal').classList.add('hidden');
}
function blockUserAction() {
  closeBlockModal();
  showSuccessToast();
}
function showSuccessToast() {
  const toast = document.getElementById('successToast');
  toast.classList.remove('hidden');
  setTimeout(() => {
    hideSuccessToast();
  }, 3000);
}
function hideSuccessToast() {
  document.getElementById('successToast').classList.add('hidden');
}
</script>

