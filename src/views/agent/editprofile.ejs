      </section>

      <!-- Deposit History -->
      <section id="panel-deposit" role="tabpanel" class="tab-panel hidden">
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700 bg-white card">
          <table class="min-w-full">
            <div class="flex flex-wrap items-center gap-4 mb-4">
              <input type="date" id="start_date1" style="color: #000000 !important;" class="border rounded px-3 py-1">
              <input type="date" id="end_date1" style="color: #000000 !important;" class="border rounded px-3 py-1">
              <input type="text" id="search1" style="color: #000000 !important;" placeholder="Search game" class="border rounded px-3 py-1">
              <button onclick="getdeposit(1)" class="bg-blue-600 text-white px-4 py-1 rounded">Filter</button>
            </div>

            <thead class="bg-gray-100 dark:bg-gray-700">
              <tr class="text-left text-sm">
                <th class="p-3">#</th>
                <th class="p-3">amount</th>
                <th class="p-3">Txn Id</th>
                <th class="p-3">status</th>
                <th class="p-3">Type</th>
                <th class="p-3">Time</th>
              </tr>
            </thead>
            <tbody id="betting_table_body1" class="text-sm">
              <!-- JS will insert rows here -->
            </tbody>

          </table>
          <div id="pagination_controls1" class="mt-4 flex gap-2"></div>
        </div>
      </section>

      <!-- Betting -->
      <section id="panel-betting" role="tabpanel" class="tab-panel hidden">
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700 bg-white card">
          <table class="min-w-full">
            <div class="flex flex-wrap items-center gap-4 mb-4">
              <input type="date" id="start_date" style="color: #000000 !important;" class="border rounded px-3 py-1">
              <input type="date" id="end_date" style="color: #000000 !important;" class="border rounded px-3 py-1">
              <input type="text" id="search" style="color: #000000 !important;" placeholder="Search game" class="border rounded px-3 py-1">
              <button onclick="getbatting(1)" class="bg-blue-600 text-white px-4 py-1 rounded">Filter</button>
            </div>

            <thead class="bg-gray-100 dark:bg-gray-700">
              <tr class="text-left text-sm">
                <th class="p-3">Game Name</th>
                <th class="p-3">Bet Amount</th>
                <th class="p-3">Win Amount</th>
                <th class="p-3">Result</th>
                <th class="p-3">P/L</th>
                <th class="p-3">Time</th>
              </tr>
            </thead>
            <tbody id="betting_table_body" class="text-sm">
              <!-- JS will insert rows here -->
            </tbody>

          </table>
          <div id="pagination_controls" class="mt-4 flex gap-2"></div>
        </div>
      </section>

      <!-- Update Profile -->
      <section id="panel-profile" role="tabpanel" class="tab-panel hidden">
        <div class="max-w-xl  rounded-2xl border border-gray-200 dark:border-gray-700 bg-white card p-6">
          <h3 class="text-lg font-semibold mb-4">Update Profile</h3>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Name</label>
              <input type="text" id="user_name"
                class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white"
                value="John Doe">
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Mobile</label>
              <input type="tel" id="user_mobile"
                class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white"
                value="">
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium mb-1">Current Password</label>
                <input type="password" id="old_password"
                  class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white"
                  placeholder="••••••••">
              </div>
              <div>
                <label class="block text-sm font-medium mb-1">New Password</label>
                <input type="password" id="new_password"
                  class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-3 py-2 focus:outline-none focus:ring focus:ring-blue-200 dark:focus:ring-blue-500 dark:text-white"
                  placeholder="New password">
              </div>
            </div>
            <button type="button" onclick="update_profile()" class="w-full sm:w-auto px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg shadow">
              Save Changes
            </button>
          </form>
        </div>
      </section>
    </div>
  </div>

  <script>
    // Simple JS to switch tabs
    (function () {
      const tabButtons = document.querySelectorAll('.tab-btn');
      const panels = document.querySelectorAll('.tab-panel');

      function activate(btn) {
        // reset buttons
        tabButtons.forEach(b => {
          b.setAttribute('aria-selected', 'false');
          b.classList.remove('text-blue-600', 'dark:text-blue-400', 'border-blue-600');
          b.classList.add('border-transparent');
        });
        // hide panels
        panels.forEach(p => p.classList.add('hidden'));

        // activate target
        const target = document.querySelector(btn.dataset.target);
        btn.setAttribute('aria-selected', 'true');
        btn.classList.add('text-blue-600', 'dark:text-blue-400', 'border-blue-600');
        btn.classList.remove('border-transparent');
        if (target) target.classList.remove('hidden');
      }

      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => activate(btn));
      });
    })();
  </script>

  <%- include('layout/footer') %>

    <!-- Block User Modal (JS version) -->
    <div id="blockUserModal"
      class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm flex items-center justify-center">
      <div class="w-full max-w-md rounded-2xl bg-white text-gray-900 shadow-xl dark:bg-gray-800 dark:text-gray-100">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700">
          <h3 class="text-lg font-semibold">Block User</h3>
          <button onclick="closeBlockModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700">
            ✕
          </button>
        </div>
        <!-- Body -->
        <form id="blockUserForm" class="px-5 py-4 space-y-4">
          <div class="text-sm">
            <p class="font-medium">User</p>
            <p class="text-gray-600 dark:text-gray-300">John Doe · ID: 12345 (Active)</p>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Duration</label>
            <select name="duration"
              class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 dark:border-gray-600 dark:bg-gray-700">
              <option value="24h">Active</option>
              <option value="permanent">Block</option>
            </select>
          </div>
        </form>
        <!-- Footer -->
        <div class="flex items-center justify-end gap-2 px-5 py-4 border-t border-gray-200 dark:border-gray-700">
          <button onclick="closeBlockModal()"
            class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100 dark:border-gray-600 dark:hover:bg-gray-700">
            Cancel
          </button>
          <button type="button" onclick="blockUserAction()"
            class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
            Block
          </button>
        </div>
      </div>
    </div>

    <!-- Success Toast -->
    <div id="successToast"
      class="fixed top-5 right-5 z-50 hidden items-center gap-3 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg shadow-lg animate-slide-in">
      <i class="fa-solid fa-circle-check text-green-500 text-xl"></i>
      <span class="font-medium" id="showerror">this demo panel !</span>
      <button onclick="hideSuccessToast()" class="ml-2 text-green-700 hover:text-green-900 font-bold">
        &times;
      </button>
    </div>

    <!-- JS -->
    <script>
      const urlParams = new URLSearchParams(window.location.search);
      const userid = urlParams.get('id');
      function openBlockModal() {
        document.getElementById('blockUserModal').classList.remove('hidden');
      }
      function closeBlockModal() {
        document.getElementById('blockUserModal').classList.add('hidden');
      }
      function blockUserAction() {
        closeBlockModal();
        showSuccessToast();
      }
      function showSuccessToast(value) {
        document.getElementById("showerror").innerHTML = value;
        const toast = document.getElementById('successToast');
        toast.classList.remove('hidden');
        setTimeout(() => {
          hideSuccessToast();
        }, 3000);
      }
      function hideSuccessToast() {
        document.getElementById('successToast').classList.add('hidden');
      }
    </script>

    <!-- dashboard -->
    <script>

      window.onload = function () {
        const token = sessionStorage.getItem('subadmin_token');
        // Create the payload object
        const payload = {
          token,
          userid
        };
        // Call the API using fetch
        fetch("/user/Udashboard", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status == 1) {
              document.getElementById('totoaldepost').innerHTML = "₹ " + data.totoaldepost;
              document.getElementById('bet_amount').innerHTML = "₹ " + data.bet_amount;
              document.getElementById('winamount').innerHTML = "₹ " + data.winamount;
              document.getElementById('getProfits').innerHTML = "₹ " + (data.bet_amount - data.winamount);
              document.getElementById('user_name').value = data.name;
              document.getElementById('user_mobile').value = data.mobile;
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }



      function getbatting(page = 1) {
        const token = sessionStorage.getItem('subadmin_token');
        const start_date = document.getElementById("start_date").value;
        const end_date = document.getElementById("end_date").value;
        const search = document.getElementById("search").value;

        const payload = {
          token,
          userid,
          page,
          start_date,
          end_date,
          search
        };

        fetch("/user/getBetting", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status == 1) {
              const tbody = document.getElementById("betting_table_body");
              tbody.innerHTML = "";

              if (data.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center p-3">No data found</td></tr>`;
              } else {
                data.data.forEach(item => {
                  const result = item.winamount > 0 ? "Win" : "Loss";
                  const profitLoss = item.winamount - item.betamount;
                  const formattedPL = profitLoss >= 0
                    ? `<span class="text-green-6  00">+₹ ${profitLoss}</span>`
                    : `<span class="text-red-600">-₹ ${Math.abs(profitLoss)}</span>`;

                  const row = `
              <tr class="border-t border-gray-100 dark:border-gray-700">
                <td class="p-3">${item.gamename}</td>
                <td class="p-3">₹ ${item.betamount}</td>
                <td class="p-3">₹ ${item.winamount}</td>
                <td class="p-3">${result}</td>
                <td class="p-3">${formattedPL}</td>
                <td class="p-3">${item.time.slice(0, 16)}</td>
              </tr>
            `;
                  tbody.insertAdjacentHTML('beforeend', row);
                });
              }

              // Pagination
              renderPagination(data.pagination.page, data.pagination.totalPages);
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }

      function renderPagination(currentPage, totalPages) {
        const pagination = document.getElementById("pagination_controls");
        pagination.innerHTML = "";

        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement("button");
          btn.textContent = i;
          btn.className = `px-3 py-1 rounded border ${i === currentPage ? 'bg-blue-600 text-white' : ''}`;
          btn.onclick = () => getbatting(i);
          pagination.appendChild(btn);
        }
      }
      // getbatting(1);


      
      function getdeposit(page = 1) {
        const token = sessionStorage.getItem('subadmin_token');
        const start_date = document.getElementById("start_date1").value;
        const end_date = document.getElementById("end_date1").value;
        const search = document.getElementById("search1").value;

        const payload = {
          token,
          userid,
          page,
          start_date,
          end_date,
          search
        };

        fetch("/user/getdeposit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status == 1) {
              const tbody = document.getElementById("betting_table_body1");
              tbody.innerHTML = "";

              if (data.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center p-3">No data found</td></tr>`;
              } else {
                data.data.forEach(item => {
                  const type = item.method > 1 ? "Online" : "Offline";
                  const status = item.status == 0 
  ? "Pending" 
  : item.status == 1 
    ? "Success" 
    : "Offline";
                  const row = `
              <tr class="border-t border-gray-100 dark:border-gray-700">
                <td class="p-3">${item.id}</td>
                <td class="p-3">₹ ${item.amount}</td>
                <td class="p-3">${item.txn_id}</td>
                <td class="p-3">${status}</td>
                <td class="p-3">${type}</td>
                <td class="p-3">${item.time.slice(0, 16)}</td>
              </tr>
            `;
                  tbody.insertAdjacentHTML('beforeend', row);
                });
              }

              // Pagination
              renderPagination1(data.pagination.page, data.pagination.totalPages);
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }

      function renderPagination1(currentPage, totalPages) {
        const pagination = document.getElementById("pagination_controls1");
        pagination.innerHTML = "";

        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement("button");
          btn.textContent = i;
          btn.className = `px-3 py-1 rounded border ${i === currentPage ? 'bg-blue-600 text-white' : ''}`;
          btn.onclick = () => getdeposit(i);
          pagination.appendChild(btn);
        }
      }
      // getdeposit(1);
      
      function update_profile(){
        let name = document.getElementById("user_name").value;
        let mobile = document.getElementById("user_mobile").value;
        let old_password = document.getElementById("old_password").value;
        let new_password = document.getElementById("new_password").value;
        if(!name || !mobile){
          showSuccessToast("fill name or mobile number");
          return ;
        }
        if(old_password !== new_password){
          showSuccessToast("password not same ");
          return ;
        }
        const token = sessionStorage.getItem('subadmin_token');
        // Create the payload object
        const payload = {
          token,
          userid,
          name,
          mobile, new_password
        };
        // Call the API using fetch
        fetch("/user/profile_update", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            'Authorization': `Bearer ${Jwt}`
          },
          body: JSON.stringify(payload)
        })
          .then(response => response.json())
          .then(data => {
            if (data.status == 1) {
              showSuccessToast(data.message);
            } else {
              showSuccessToast(data.message || "Something went wrong.");
            }
          })
          .catch(error => {
            console.error("API Error:", error);
            showSuccessToast("Could not connect to server.");
          });
      }


    </script>
    </script>