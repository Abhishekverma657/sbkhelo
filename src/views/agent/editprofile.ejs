<%- include('layout/header') %>
  <div class="m-5">
    <!-- Tabs -->
    <div id="tabs" role="tablist" class="flex flex-wrap gap-1 border-b border-gray-300 dark:border-gray-700">
      <button role="tab" aria-selected="true" data-target="#panel-dashboard"
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 dark:text-blue-400">
        Dashboard
      </button>
      <button role="tab" aria-selected="false" onclick="getdeposit(1)" data-target="#panel-deposit"
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent hover:text-blue-600 hover:border-blue-500 dark:hover:text-blue-400">
        Deposit History
      </button>
      <button role="tab" onclick="getbatting()" aria-selected="false" data-target="#panel-betting"
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent hover:text-blue-600 hover:border-blue-500 dark:hover:text-blue-400">
        Betting
      </button>
      <button role="tab" aria-selected="false" data-target="#panel-profile"
        class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent hover:text-blue-600 hover:border-blue-500 dark:hover:text-blue-400">
        Update Profile
      </button>
    </div>

    <!-- Panels -->
    <div class="mt-4">
      <!-- Dashboard -->
      <section id="panel-dashboard" role="tabpanel" class="tab-panel">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="p-4 rounded-xl border bg-white  card">
            <p class="text-sm text-gray-500">Total Deposits</p>
            <p class="text-2xl font-semibold mt-1" id="totoaldepost">₹ Loading...</p>
          </div>
          <div class="p-4 rounded-xl border bg-white  card">
            <p class="text-sm text-gray-500 dark:text-gray-400">Bet Amount</p>
            <p class="text-2xl font-semibold mt-1" id="bet_amount">Loading</p>
          </div>
          <div class="p-4 rounded-xl border bg-white  card">
            <p class="text-sm text-gray-500 dark:text-gray-400">Win Amount</p>
            <p class="text-2xl font-semibold mt-1" id="winamount">Loading</p>
          </div>
          <div class="p-4 rounded-xl border bg-white  card">
            <p class="text-sm text-gray-500 dark:text-gray-400">Profit (30d)</p>
            <p class="text-2xl font-semibold mt-1 text-green-600" id="getProfits">+₹ 9,430</p>
          </div>
